# Telegram bot token from @BotFather (a NEW bot, separate from the Italian/AI tutor bots)
TELEGRAM_BOT_TOKEN=123456789:AA...

# Anthropic API key from console.anthropic.com (billing must be enabled)
ANTHROPIC_API_KEY=sk-ant-...

# The admin's Telegram @username WITHOUT the leading @ (used for first-boot admin self-bootstrap, §13).
# On first boot the bot auto-creates an active admin row for this username; the admin then sends
# /start once to link their chat id.
ADMIN_TELEGRAM_USERNAME=your_telegram_username

# Where the SQLite DB lives. On Railway, point this INSIDE the mounted persistent volume, e.g. /data/mmed_bot.db
DATABASE_PATH=mmed_bot.db
